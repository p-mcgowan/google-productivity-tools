{
  "manifest_version": 3,
  "name": "Tab volume",
  "version": "1.0",
  "description": "Adjust tab volume",
  "icons": {
    "16": "tab-volume.png"
  },
  "action": {
    "default_icon": "tab-volume.png",
    "default_popup": "js/popup/popup.html"
  },

  "background": {
    "service_worker": "./js/background/background.js",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "tabCapture"
  ]
}
