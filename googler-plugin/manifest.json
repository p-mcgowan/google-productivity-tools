{
  "manifest_version": 3,
  "name": "Googler",
  "version": "1.0",
  "description": "Efficientize your Googling",
  "icons": {
    "16": "googler.png"
  },
  "options_ui": {
    "page": "js/options/options.html"
  },
  "omnibox": {
    "keyword": "k"
  },
  "commands": {
    "launch-googler": {
      "suggested_key": {
        "default": "Ctrl+Space"
      },
      "description": "Toggle feature foo"
    }
  },
  "permissions": [
    "activeTab",
    "bookmarks",
    "history",
    "tabs",
    "scripting",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback"
  ],
  "action": {
    "default_icon": "googler.png",
    "default_popup": "js/popup/popup.html"
  },
  "host_permissions": ["https://ajax.googleapis.com/"],
  "declarative_net_request": {
    "rule_resources": [
      { "id": "disable-csp", "enabled": true, "path": "csp.json" }
    ]
  }
}
